<!-- themes/your-theme-name/layout/thoughts.ejs -->
<article id="page-<%= page.layout %>" class="article article-type-<%= page.layout %>">
    <div class="article-inner">
        <% if (page.abstract) { %>
            <blockquote class="thoughts-abstract">
                <p>
                    <%- page.abstract %>
                </p>
            </blockquote>
            <% } %>
                <% if (page.thought_years && page.thought_years.length > 1) { %>
                    <nav class="thoughts-years">
                        <% page.thought_years.forEach(function(y, i){
                            var latest = (y === page.thought_years[0]);
                            var href = latest ? '/thoughts/' : '/thoughts/' + y + '/';
                            var label = latest ? '最新' : y;
                            var current = String(page.thought_year) === String(y); %>
                            <% if (i > 0) { %><span class="sep">·</span><% } %>
                            <% if (current) { %><span class="current"><%= label %></span><% } else { %><a href="<%= href %>"><%= label %></a><% } %>
                        <% }) %>
                    </nav>
                <% } %>
                <div class="article-entry">
                    <% var groups = page.thought_groups ||
                        (page.thoughts && page.thoughts.length ? [{ year: null, thoughts: page.thoughts }] : []); %>
                    <% if (groups.length) { %>
                        <% groups.forEach(function(group, gi){ %>
                            <% if (gi > 0 && group.year) { %>
                                <div class="thoughts-year-divider"><span><%= group.year %></span></div>
                            <% } %>
                            <% group.thoughts.forEach(function(thought){ %>
                                <div class="thought">
                                    <div class="thought-content">
                                        <% thought.content.split('\n\n').forEach(function(para) { %>
                                            <% if(para.trim()) { %>
                                                <%- markdown(para.trim()) %>
                                            <% } %>
                                        <% }); %>
                                    </div>
                                    <div class="thought-timestamp">
                                        <% var date=new Date(thought.timestamp); var formattedDate=date.getFullYear() + '-'
                                            + ('0' + (date.getMonth() + 1)).slice(-2) + '-' + ('0' +
                                            date.getDate()).slice(-2) + ' ' + ('0' + date.getHours()).slice(-2) + ':' + ('0'
                                            + date.getMinutes()).slice(-2); %>
                                            <%= formattedDate %>
                                    </div>
                                </div>
                            <% }) %>
                        <% }) %>
                    <% } else { %>
                        <p>No thoughts yet.</p>
                    <% } %>
                </div>
                <% if (page.thought_next_year) { %>
                    <button class="thoughts-more" type="button"
                        data-next="<%= page.thought_next_year %>"
                        data-years="<%= page.thought_years.join(',') %>">↓ <%= page.thought_next_year %></button>
                <% } %>
    </div>
</article>
