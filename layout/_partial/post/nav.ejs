<%
// Keep OLDER/NEWER navigation within the same language:
// walk the prev/next chains and skip posts written in the other language.
var navLang = (post.language === 'en') ? 'en' : 'zh';
var sameLang = function (p) { return ((p.language === 'en') ? 'en' : 'zh') === navLang; };
var newerPost = post.prev;
while (newerPost && !sameLang(newerPost)) newerPost = newerPost.prev;
var olderPost = post.next;
while (olderPost && !sameLang(olderPost)) olderPost = olderPost.next;
%>
<% if (newerPost || olderPost){ %>
<nav id="article-nav">
  <% if (newerPost){ %>
    <a href="<%- url_for(newerPost.path, {relative: false}) %>" id="article-nav-newer" class="article-nav-link-wrap">
      <strong class="article-nav-caption"><%= __('newer') %></strong>
      <div class="article-nav-title">
        <% if (newerPost.title){ %>
          <%= newerPost.title %>
        <% } else { %>
          (no title)
        <% } %>
      </div>
    </a>
  <% } %>
  <% if (olderPost){ %>
    <a href="<%- url_for(olderPost.path, {relative: false}) %>" id="article-nav-older" class="article-nav-link-wrap">
      <strong class="article-nav-caption"><%= __('older') %></strong>
      <div class="article-nav-title">
        <% if (olderPost.title){ %>
          <%= olderPost.title %>
        <% } else { %>
          (no title)
        <% } %>
      </div>
    </a>
  <% } %>
</nav>
<% } %>
