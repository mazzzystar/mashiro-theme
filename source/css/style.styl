@import "nib"
@import "_variables"
@import "_util/mixin"
@import "_util/grid"
@import "_extend"

global-reset()

input, button
  margin: 0
  padding: 0
  &::-moz-focus-inner
    border: 0
    padding: 0

@font-face
  font-family: FontAwesome
  font-style: normal
  font-weight: normal
  src: url("/fonts/fontawesome-webfont.woff2") format("woff2")
  font-display: block

// Chinese fonts are now defined in font-subset.css
// This prevents loading the full large font files

@font-face
  font-family: biaodian;
  src: url("fonts/biaodian.woff2") format("woff2");
  unicode-range: U+FF0E, U+2014, U+2026, U+00B7, U+201C-201D, U+2018-2019, U+25CF,
    U+3002, U+FF0C, U+3001,
    U+FF1B, U+FF1A, U+FF1F, U+FF01,
    U+FF0D, U+FF0F, U+FF3C,
    U+300C-300F,
    U+300A-300B, U+3008-3009, U+FF08-FF09, U+3014-3015

html
  scroll-padding-top: 80px;

html, body, #container
  height: 100%


// Default font stack (will be used on macOS and other non-Windows systems)
body
  font: font-size font-serif
  -webkit-text-size-adjust: 100%
  background: color-background

#content
  margin: 0 auto
  @extend $variable-width

.outer
  clearfix()
  margin: 0 auto
  @extend $variable-width

.inner
  column(columns)

.left, .alignleft
  float: left

.right, .alignright
  float: right

.clear
  clear: both

#container
  position: relative

.mobile-nav-on
  overflow: hidden

#wrap
  height: 100%
  width: 100%
  position: absolute
  top: 0
  left: 0
  transition: 0.2s ease-out
  z-index: 1
  background: color-background
  display: flex
  flex-direction: column
  .mobile-nav-on &
    left: 50%

if sidebar and sidebar isnt bottom
  #main
    @media mq-normal
      column(main-column)

if sidebar is left
  @media mq-normal
    #main
      float: right

#main-404
  font-size: 40px
  font-weight: bold
  font-family: font-serif
  text-align: center
  margin: 100px 0

a
  transition: 0.2s

@import "_partial/header"
@import "_partial/article"
@import "_partial/archive"
@import "_partial/footer"
@import "_partial/highlight"
@import "_partial/mobile"
@import "_partial/about"
@import "_partial/bilibili"
@import "_partial/toc"
@import "_partial/biaodian"
@import "_partial/thoughts"

if sidebar
  @import "_partial/sidebar"

#main-nav-toggle
  display: none
  @media screen and (max-width: 768px)
    display: block

// Mobile padding fix
@media screen and (max-width: 470px)
  #content, .outer
    width: auto !important
    max-width: 100%
    padding: 0 1.25rem
    box-sizing: border-box

// Add language switch button styles
.lang-switch
  color: #666
  text-decoration: none
  cursor: pointer
  padding: 5px 10px
  border-radius: 3px
  transition: color 0.2s ease-in-out

  &:hover
    color: #333
    text-decoration: none

// ===== Reading polish (quiet-classical typography, 2026-07) =====
// Links: ink text with a muted warm underline
.article-entry a
  color: color-default
  text-decoration: underline
  text-decoration-color: rgba(150, 143, 132, 0.6)
  text-decoration-thickness: 1px
  text-underline-offset: 0.2em
  transition: text-decoration-color 0.15s
  &:hover
    text-decoration-color: currentColor

// Headings attach to the section they open
.article-entry h1, .article-entry h2, .article-entry h3,
.article-entry h4, .article-entry h5, .article-entry h6
  line-height: 1.3
  margin: 2em 0 0.85em

// Images: soft corners on the paper background
.article-entry img
  border-radius: 4px

// Code: quieter size, relative leading
.article-entry .highlight, .article-entry pre
  line-height: 1.7
.article-entry pre
  font-size: 0.88em
.article-entry code
  font-size: 0.92em
.article-entry pre code
  font-size: 1em

// Tables: slightly condensed, book-style
.article-entry table
  font-size: 0.93em

// Uppercase labels breathe
.article-entry .code-block-lang, .article-nav-caption
  letter-spacing: 0.08em

// hr: short, centered, breathing room
.article-entry hr
  border: 0
  border-top: 1px solid currentColor
  opacity: 0.22
  width: 38%
  margin: 2.6em auto

// English posts: justified text needs hyphenation to avoid rivers
html[lang="en"] .article-entry p
  -webkit-hyphens: auto
  hyphens: auto

// Subtle warm selection tint
::selection
  background: rgba(180, 160, 120, 0.35)
