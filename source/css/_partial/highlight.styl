highlight-background = #f3f3f1
highlight-toolbar = #e9e9e6
highlight-current-line = #e7e7e3
highlight-selection = #d9d9d3
highlight-foreground = #252321
highlight-comment = #8a8378
highlight-red = #b54b4b
highlight-orange = #a76528
highlight-yellow = #8a6d18
highlight-green = #5c7a34
highlight-aqua = #287b76
highlight-blue = #356fa6
highlight-purple = #8558a3

$code-block
  background: highlight-background
  margin: 0
  border: 1px solid rgba(183,181,172,0.85)
  border-radius: 10px
  overflow: hidden
  color: highlight-foreground
  line-height: font-size * line-height

$line-numbers
  color: #666
  font-size: 0.85em

.article-entry
  pre, code
    font-family: font-mono
  code
    background: rgba(242,242,240,0.9)
    border: 1px solid rgba(183,181,172,0.36)
    border-radius: 4px
    color: #3f3a33
    text-shadow: none
    padding: 0.05em 0.32em
  pre
    @extend $code-block
    padding: 16px
    overflow: auto
    code
      background: none
      border: none
      border-radius: 0
      color: inherit
      text-shadow: none
      padding: 0
  .highlight
    @extend $code-block
    margin-top: 20px
    margin-bottom: 20px
    padding: 0
    pre
      border: none
      border-radius: 0
      margin: 0
      padding: 16px
      background: transparent
      overflow: auto
      white-space: pre
    code
      border: none
      background: transparent
      color: inherit
      padding: 0
  .highlight.is-collapsed
    pre
      display: none
  .answer-block
    border: 1px solid rgba(183,181,172,0.76)
    border-radius: 12px
    background: rgba(250,249,246,0.66)
    margin: line-height 0
    overflow: hidden
    summary
      display: flex
      align-items: center
      justify-content: space-between
      gap: 12px
      cursor: pointer
      color: color-default
      font-weight: bold
      list-style: none
      padding: 0.9em 1.15em
      &::-webkit-details-marker
        display: none
      &:after
        content: "展开"
        color: color-grey
        flex: 0 0 auto
        font-size: 0.82em
        font-weight: normal
  .answer-block[open]
    summary
      border-bottom: 1px solid rgba(183,181,172,0.52)
      &:after
        content: "收起"
  .answer-block-content
    padding: 0.25em 1.15em 1.05em
    > :first-child
      margin-top: 0.8em
    > :last-child
      margin-bottom: 0
  .gist
    margin: 0 article-padding * -1
    border-style: solid
    border-color: color-border
    border-width: 1px 0
    background: highlight-background
    padding: 15px article-padding 15px 0
    .gist-file
      border: none
      font-family: font-mono
      margin: 0
      .gist-data
        background: none
        border: none
        .line-numbers
          @extend $line-numbers
          background: none
          border: none
          padding: 0 20px 0 0
        .line-data
          padding: 0 !important
      .highlight
        margin: 0
        padding: 0
        border: none
      .gist-meta
        background: highlight-background
        color: highlight-comment
        font: 0.85em font-sans
        text-shadow: 0 0
        padding: 0
        margin-top: 1em
        margin-left: article-padding
        a
          color: color-link
          font-weight: normal
          &:hover
            text-decoration: underline

pre
  .hljs-comment
  .hljs-title
    color: highlight-comment
  .hljs-variable
  .hljs-attribute
  .hljs-tag
  .hljs-regexp
  .hljs-ruby .hljs-constant
  .hljs-xml .hljs-tag .hljs-title
  .hljs-xml .hljs-pi
  .hljs-xml .hljs-doctype
  .hljs-html .hljs-doctype
  .hljs-css .hljs-id
  .hljs-css .hljs-class
  .hljs-css .hljs-pseudo
    color: highlight-red
  .hljs-number
  .hljs-preprocessor
  .hljs-built_in
  .hljs-literal
  .hljs-params
  .hljs-constant
    color: highlight-orange
  .hljs-class
  .hljs-ruby .hljs-class .hljs-title
  .hljs-css .hljs-rules .hljs-attribute
    color: highlight-green
  .hljs-string
  .hljs-value
  .hljs-inheritance
  .hljs-header
  .hljs-ruby .hljs-symbol
  .hljs-xml .hljs-cdata
    color: highlight-green
  .hljs-css .hljs-hexcolor
    color: highlight-aqua
  .hljs-function
  .hljs-python .hljs-decorator
  .hljs-python .hljs-title
  .hljs-ruby .hljs-function .hljs-title
  .hljs-ruby .hljs-title .hljs-keyword
  .hljs-perl .hljs-sub
  .hljs-javascript .hljs-title
  .hljs-coffeescript .hljs-title
    color: highlight-blue
  .hljs-keyword
  .hljs-javascript .hljs-function
    color: highlight-purple
